# --- Base de données Supabase (PostgreSQL) ---
# Récupère cette chaîne dans Supabase > Project Settings > Database > Connection string (URI, mode "Transaction")
DATABASE_URL=postgresql://postgres:xxxxx@xxxxx.pooler.supabase.com:6543/postgres

# --- Supabase Storage (pour les photos) ---
# Project Settings > API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=photos

# --- Sécurité admin ---
# Hash bcrypt de ton code secret. Génère-le avec : node server/hash-code.js "MonCodeSecret123"
ADMIN_CODE_HASH=$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret utilisé pour signer le token de session admin (chaîne aléatoire longue)
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# --- Numéro WhatsApp par défaut (optionnel, indicatif inclus, sans + ni espaces) ---
# Utilisé seulement si jamais tu veux un numéro de secours (non obligatoire)

# --- Serveur ---
PORT=3000
